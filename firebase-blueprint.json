{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Financial income or expense transaction",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
       "required": ["type", "amount", "date", "ownerId"]
    },
    "Entity": {
      "title": "Entity",
      "description": "Supplier or customer entity",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "ownerId"]
    },
    "LedgerEntry": {
      "title": "Ledger Entry",
      "description": "Unified accounting ledger entry",
      "type": "object",
      "properties": {
        "sourceType": { "type": "string" },
        "sourceId": { "type": "string" },
        "userId": { "type": "string" },
        "branchId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "debit": { "type": "number" },
        "credit": { "type": "number" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "entityId": { "type": "string" },
        "entityName": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["sourceType", "sourceId", "userId", "branchId", "date", "amount", "ownerId"]
    },
    "UserSettings": {
      "title": "User Settings",
      "description": "Application settings for a user",
      "type": "object",
      "properties": {
        "syncSettings": { "type": "object" },
        "imageSettings": { "type": "object" }
      }
    },
    "OpeningCash": {
      "title": "Opening Cash",
      "description": "Carried forward balance or opening starting cash",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "source": { "type": "string" },
        "branchId": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["amount", "date", "month", "year", "source", "branchId", "ownerId"]
    },
    "supplierOpeningBalances": {
      "title": "Supplier Opening Balance",
      "description": "Initial balance tracking for suppliers",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "supplierType": { "type": "string" },
        "openingAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "branchId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["supplierId", "openingAmount", "remainingAmount", "ownerId"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Loans and returned deposits",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["outgoing", "returned"] },
        "partyName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "partially_returned", "fully_returned", "overdue"] },
        "date": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["type", "partyName", "amount", "status", "date", "ownerId", "branchId"]
    },
    "SystemConfig": {
      "title": "System Configuration",
      "description": "Global settings for app versioning and updates",
      "type": "object",
      "properties": {
        "appVersion": { "type": "string" },
        "schemaVersion": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "forceUpdate": { "type": "boolean" }
      }
    },
    "MedicineRequest": {
      "title": "Medicine Request",
      "description": "Customer request for unavailable medicine",
      "type": "object",
      "properties": {
        "patientName": { "type": "string" },
        "phone": { "type": "string" },
        "medicineName": { "type": "string" },
        "quantity": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "provided", "notified"] },
        "notes": { "type": "string" },
        "imageUrl": { "type": "string" },
        "branchId": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientName", "phone", "medicineName", "status", "ownerId"]
    },
    "License": {
      "title": "License",
      "description": "Software license control document",
      "type": "object",
      "properties": {
        "licenseKey": { "type": "string" },
        "planType": { "type": "string", "enum": ["basic", "pro", "lifetime"] },
        "status": { "type": "string", "enum": ["active", "expired", "suspended", "revoked", "unused"] },
        "ownerUserId": { "type": "string" },
        "ownerName": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "ownerPhone": { "type": "string" },
        "maxDevices": { "type": "number" },
        "maxBranches": { "type": "number" },
        "activatedDevices": { "type": "array" },
        "activatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "notes": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["paid", "pending", "manual"] }
      },
      "required": ["licenseKey", "planType", "status"]
    },
    "DailyBackup": {
      "title": "Daily Backup",
      "description": "Daily automatic customer backup snapshot containing all records and counts",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "backupDate": { "type": "string", "format": "date-time" },
        "dayString": { "type": "string" },
        "recordCounts": { "type": "object" },
        "totalRecordsCount": { "type": "number" },
        "data": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "backupDate", "dayString", "totalRecordsCount", "data", "createdAt"]
    },
    "EmployeeCheckIn": {
      "title": "Employee Check-In",
      "description": "Daily smart attendance clock check-in and check-out logs for employees",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "pharmacyId": { "type": "string" },
        "branchId": { "type": "string" },
        "checkInTime": { "type": "string" },
        "checkOutTime": { "type": "string" },
        "totalHours": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "dateStr": { "type": "string" },
        "deviceInfo": { "type": "string" },
        "status": { "type": "string", "enum": ["checked_in", "checked_out"] },
        "ownerId": { "type": "string" }
      },
      "required": ["employeeId", "employeeName", "pharmacyId", "branchId", "checkInTime", "date", "dateStr", "status", "ownerId"]
    }
  },
  "firestore": {
    "transactions": { "schema": "Transaction", "description": "Global transactions" },
    "entities": { "schema": "Entity", "description": "Suppliers and accounts" },
    "ledgerEntries": { "schema": "LedgerEntry", "description": "Detailed accounting" },
    "branches": { "schema": "object", "description": "Pharmacy branches" },
    "medicineRequests": { "schema": "MedicineRequest", "description": "Customer medicine requests" },
    "historicalRecords": { "schema": "object", "description": "Past data migration" },
    "settings": { "schema": "UserSettings", "description": "User preferences and sync settings" },
    "notifications": { "schema": "object", "description": "System notifications" },
    "customerDebts": { "schema": "object", "description": "Customer debts" },
    "deadlines": { "schema": "object", "description": "Payment deadlines" },
    "employees": { "schema": "object", "description": "Staff data" },
    "employeeAttendance": { "schema": "object", "description": "Staff attendance" },
    "bonuses": { "schema": "object", "description": "Bonus records" },
    "expiredDamagedLosses": { "schema": "object", "description": "Records of expired and damaged items" },
    "announcements": { "schema": "object", "description": "System announcements" },
    "announcementReads": { "schema": "object", "description": "Announcements read status" },
    "activationCodes": { "schema": "object", "description": "App activation codes" },
    "activationRequests": { "schema": "object", "description": "Activation requests" },
    "recoveryRequests": { "schema": "object", "description": "Account recovery" },
    "entityActivities": { "schema": "object", "description": "Tracking entity actions" },
    "openingCash": { "schema": "OpeningCash", "description": "Opening cash records" },
    "supplierOpeningBalances": { "schema": "SupplierOpeningBalance", "description": "Supplier initial tracking" },
    "loans": { "schema": "Loan", "description": "Loans and returned deposits records" },
    "system": { "schema": "SystemConfig", "description": "Global app version and config" },
    "licenses": { "schema": "License", "description": "SaaS license details" },
    "employeeCheckIns": { "schema": "EmployeeCheckIn", "description": "Daily employee check-in and check-out logs" },
    "systemLogs": { "schema": "object", "description": "System operation logs" },
    "dailyBackups": { "schema": "DailyBackup", "description": "Daily automatic snapshots of user collections" }
  }
}